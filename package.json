{
  "name": "web",
  "version": "1.0.0",
  "description": "ParaDiced Web Client - A simple Web UI client for ParaDiced game",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:web && npm run lint:go",
    "lint:web": "biome ci --formatter-enabled=false .",
    "lint:go": "golangci-lint run",
    "format": "npm run format:web && npm run format:go",
    "format:web": "biome check --write .",
    "format:go": "golangci-lint fmt",
    "preview": "vite preview"
  },
  "dependencies": {
    "@heroiclabs/nakama-js": "^2.8.0",
    "colyseus.js": "^0.15.28",
    "phaser": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1"
  }
}
